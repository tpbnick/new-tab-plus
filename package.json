{
  "name": "new-tab-plus",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run icons && npm run build-info && vite",
    "icons": "node scripts/generate-icons.mjs",
    "build-info": "node scripts/generate-build-info.mjs",
    "build": "npm run icons && npm run build-info && tsc --noEmit && vite build",
    "package": "node scripts/zip.mjs",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.0",
    "@types/chrome": "^0.2.0",
    "archiver": "^8.0.0",
    "happy-dom": "^20.10.6",
    "sharp": "^0.35.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.0",
    "vitest": "^4.0.0"
  }
}
