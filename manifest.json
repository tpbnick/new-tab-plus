{
  "manifest_version": 3,
  "name": "New Tab Plus",
  "version": "1.0.1",
  "description": "A bookmarks-driven, widget-extensible new tab page.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "New Tab Plus",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": ["bookmarks", "topSites", "sessions", "storage", "favicon", "search"],
  "host_permissions": [
    "https://geocoding-api.open-meteo.com/*",
    "https://api.open-meteo.com/*",
    "https://fonts.googleapis.com/*",
    "https://fonts.gstatic.com/*"
  ],
  "chrome_url_overrides": { "newtab": "src/newtab/index.html" }
}
